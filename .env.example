# Copy to .env.local for local dev, and add the same vars in Vercel → Settings → Environment Variables.
# The app runs fine with these blank (history stays on the device). Fill them to enable accounts + cloud sync.

# Clerk (auth) — from Clerk dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Supabase (history storage) — from Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx
